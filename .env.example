# ============================================
# Yen Lee Fireweld — Developer Backend Config
# ============================================
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to git.
# NEVER expose these values in any frontend code.

# Developer login credentials (checked server-side only)
DEV_USERNAME=yenleefireweld@2026
DEV_PASSWORD=Swaroop@yenlee

# Long, random secret used to sign login sessions (JWT).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# How long a developer login session lasts
JWT_EXPIRES_IN=8h

# Port the server runs on
PORT=4000

# Comma-separated list of allowed origins for CORS
# (the domain(s) your website is served from)
ALLOWED_ORIGINS=https://www.yenleefireweld.com,http://localhost:4000

# Max upload size per file, in MB
MAX_UPLOAD_MB=25
